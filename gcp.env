# GCP foundation for Lumina Studio Agent (Google for Startups AI Agents Challenge)
# Verified 2026-06-01 by querying live Vertex APIs. Source of truth for the build phase.
# Non-secret (IDs only — no tokens/keys here).

# --- Project / identity ---
GCP_PROJECT_ID=aifreelance-hackathon
GCP_PROJECT_NUMBER=587790795280
GCP_ACCOUNT=<your-google-account>
GCP_BILLING_ACCOUNT=<redacted>                    # $500 hackathon credits attached here

# --- Regions / endpoints (IMPORTANT) ---
# Gemini 3.x (text AND image) require the GLOBAL endpoint. A regional endpoint => model-not-found.
GEMINI_LOCATION=global
# Veo (video) exists ONLY in us-central1 among checked regions (us-east4/europe-west4 had Imagen but NO Veo).
# us-central1 is also the richest region (132 publisher models) and our data region.
VERTEX_REGION=us-central1
GCS_REGION=us-central1
FIRESTORE_LOCATION=us-central1

# --- Storage / state ---
GCS_BUCKET=aifreelance-hackathon-lumina-assets    # regional us-central1, uniform bucket-level access
FIRESTORE_DATABASE=(default)                       # FIRESTORE_NATIVE, us-central1
# NOTE: a pre-existing DB "ai-studio-<uuid>" sits in asia-southeast1 — ignore it, we use (default).

# --- Verified model IDs (from Vertex publisher-models API, 2026-06-01) ---
MODEL_REASONING=gemini-3.5-flash                  # orchestration/planning/QA; verify multimodal-QA at build. alt: gemini-3-flash-preview
MODEL_REASONING_PRO=gemini-3.1-pro-preview        # heavy reasoning if Flash underperforms
MODEL_IMAGE=gemini-3.1-flash-image                # Nano Banana 2 — default image gen (GA, no -preview)
MODEL_IMAGE_PRO=gemini-3-pro-image                # Nano Banana Pro — hero shots (cost↑)
MODEL_VIDEO=veo-3.1-fast-generate-001             # cheap/fast for demo. alt: veo-3.1-lite-generate-001 (cheapest), veo-3.1-generate-001 (quality)

# --- SDK note (CRITICAL) ---
# Use the Google Gen AI SDK (pip install google-genai) with the Vertex backend.
# The old vertexai.generative_models / language_models / vision_models is REMOVED on 2026-06-24 — do NOT use it.
# Client init pattern:
#   from google import genai
#   client = genai.Client(vertexai=True, project="aifreelance-hackathon", location="global")      # Gemini text+image
#   veo_client = genai.Client(vertexai=True, project="aifreelance-hackathon", location="us-central1")  # Veo video

# --- Enabled APIs ---
# aiplatform, run, cloudbuild, artifactregistry, cloudresourcemanager, cloudtrace,
# discoveryengine (Vertex AI Search/RAG), firestore, iam, iamcredentials, storage

# --- Remaining setup before running agent code locally ---
# 1) ADC for local dev:  gcloud auth application-default login
#                        gcloud auth application-default set-quota-project aifreelance-hackathon
# 2) (deploy time) dedicated service account for Agent Engine + roles/iam.serviceAccountTokenCreator for signed URLs

# --- Deployed Agent Engine instance (2026-06-01) ---
AGENT_ENGINE_ID=4329993888170246144
AGENT_ENGINE_RESOURCE=projects/587790795280/locations/us-central1/reasoningEngines/4329993888170246144
# Update in place:  .venv/bin/adk deploy agent_engine --agent_engine_id 4329993888170246144 --project aifreelance-hackathon --region us-central1 --trace_to_cloud --env_file .env --requirements_file requirements.txt lumina
# Deploy needs `google-cloud-aiplatform[agent_engines]` in the venv (provides `vertexai`); NOT a runtime/requirements.txt dep.
# Runtime identities granted bucket access (else image upload 403s): gcp-sa-aiplatform-re SA + agents principalSet => objectAdmin; gcp-sa-aiplatform SA => objectViewer.
# Query: vertexai.agent_engines.get(RESOURCE).create_session(user_id=..) then .stream_query(user_id=, session_id=, message=). See test_remote.py.
